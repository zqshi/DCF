{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dcf.runtime.task.event.v1",
  "title": "Runtime Task Event v1",
  "type": "object",
  "required": [
    "id",
    "type",
    "taskId",
    "payload",
    "at",
    "source"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" },
    "at": { "type": "string", "minLength": 1 },
    "source": {
      "type": "string",
      "enum": [ "openclaw", "self-hosted", "skills-runtime" ]
    }
  },
  "additionalProperties": true
}

