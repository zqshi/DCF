DB_DRIVER=sqlite
SQLITE_PATH=./data/dcf.sqlite
HOST=127.0.0.1
PORT=8092

# Local-only runtime dependencies (Docker)
EXECUTION_ENGINE=openclaw
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_REQUIRE_AUTH=1
OPENCLAW_GATEWAY_TOKEN=replace-with-local-openclaw-token
OPENCLAW_ENFORCE_POLICY_FOR_L4=1
OPENCLAW_SANDBOX_PROFILE=strict
OPENCLAW_ALLOWED_HOSTS=127.0.0.1,localhost
OPENCLAW_ALLOWED_TOOLS=bash,read,write,search,test,browser,cron,nodes,canvas,gateway,discord,slack,telegram,whatsapp
OPENCLAW_DENIED_TOOLS=
OPENCLAW_DEFAULT_TOOL_SCOPE=bash,read,write,search,test,browser,cron,nodes,canvas,gateway,discord,slack,telegram,whatsapp
OPENCLAW_TIMEOUT_MS=12000

# Local-only knowledge service (Docker)
WEKNORA_BASE_URL=http://127.0.0.1:19080
WEKNORA_API_KEY=replace-with-local-knowledge-api-key
WEKNORA_TIMEOUT_MS=8000
WEKNORA_WEB_URL=http://127.0.0.1:19080
FRONT_KNOWLEDGE_ENTRY_ENABLED=1
FRONT_KNOWLEDGE_ENTRY_MODE=external
KNOWLEDGE_SSO_BRIDGE_ENABLED=1
KNOWLEDGE_SSO_BRIDGE_SHARED_SECRET=replace-with-local-bridge-secret
KNOWLEDGE_SSO_BRIDGE_ISSUER=dcf
KNOWLEDGE_SSO_BRIDGE_AUDIENCE=weknora
KNOWLEDGE_SSO_BRIDGE_TTL_SECONDS=120
KNOWLEDGE_SSO_BRIDGE_LOGIN_PATH=/login
KNOWLEDGE_SSO_BRIDGE_REDIRECT_PATH=/platform/knowledge-bases

# LLM still local-configurable; avoid hard-coding remote credentials
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=
