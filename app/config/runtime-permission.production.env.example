# Production baseline for digital employee runtime permission strategy.

# Core runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=8092
DB_DRIVER=sqlite
SQLITE_PATH=./data/dcf.sqlite

# Auth hardening (required in production)
AUTH_USERS_FILE=./config/admin-users.production.json
AUTH_PASSWORD_PEPPER=replace-with-strong-secret
AUTH_REQUIRE_EXTERNAL_USERS=1
AUTH_FORBID_DEMO_USERS=1
AUTH_SINGLE_SESSION_PER_USER=1
AUTH_SESSION_SLIDING=1
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MS=900000
AUTH_FAIL_WINDOW_MS=600000
CORS_ALLOW_ORIGIN=https://admin.example.com

# Execution engine
EXECUTION_ENGINE=openclaw
OPENCLAW_BASE_URL=https://openclaw-runtime.example.com
OPENCLAW_REQUIRE_AUTH=1
OPENCLAW_API_KEY=replace-with-openclaw-token
OPENCLAW_ENFORCE_POLICY_FOR_L4=1
OPENCLAW_SANDBOX_PROFILE=hardened

# Default-allow strategy (except sensitive actions escalated to L4 approval)
OPENCLAW_ALLOWED_HOSTS=*
OPENCLAW_ALLOWED_TOOLS=bash,read,write,search,test,browser,cron,nodes,canvas,gateway,discord,slack,telegram,whatsapp
OPENCLAW_DENIED_TOOLS=

# Optional LLM (if dialogue output is required)
# OPENAI_API_KEY=replace-with-openai-key
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com
