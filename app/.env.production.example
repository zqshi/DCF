# Production baseline (non-secret template)
NODE_ENV=production
DB_DRIVER=sqlite
SQLITE_PATH=./data/dcf.sqlite
HOST=127.0.0.1
PORT=8091
CORS_ALLOW_ORIGIN=https://admin.example.com
EXECUTION_ENGINE=openclaw
SELF_HOSTED_RUNTIME_ENABLED=1
OPENCLAW_REQUIRE_AUTH=1
OPENCLAW_ALLOWED_HOSTS=openclaw.internal.example.com
OPENCLAW_ALLOWED_TOOLS=read,write,search,test
OPENCLAW_DENIED_TOOLS=browser,cron,nodes,canvas,gateway,discord,slack,telegram,whatsapp
OPENCLAW_DEFAULT_TOOL_SCOPE=read,write,search,test
OPENCLAW_ENFORCE_POLICY_FOR_L4=1
OPENCLAW_SANDBOX_PROFILE=hardened

# Auth hardening (required in production)
AUTH_USERS_FILE=./config/admin-users.production.json
AUTH_PASSWORD_PEPPER=replace-with-strong-secret
AUTH_REQUIRE_EXTERNAL_USERS=1
AUTH_FORBID_DEMO_USERS=1
AUTH_SESSION_SLIDING=1
AUTH_SINGLE_SESSION_PER_USER=1
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MS=900000
AUTH_FAIL_WINDOW_MS=600000

# Optional runtime bridge
# OPENCLAW_BASE_URL=https://openclaw.internal.example.com
# OPENCLAW_API_KEY=replace-with-runtime-token
# OPENCLAW_GATEWAY_TOKEN=replace-with-gateway-token
