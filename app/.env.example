# Driver: memory | sqlite | postgres
DB_DRIVER=memory

# SQLite mode
SQLITE_PATH=./data/dcf.sqlite

# Postgres mode
POSTGRES_URL=postgres://user:pass@localhost:5432/dcf

# Server
HOST=127.0.0.1
PORT=8091

# Execution runtime engine: openclaw | self_hosted | auto
EXECUTION_ENGINE=openclaw
SELF_HOSTED_RUNTIME_ENABLED=1
OPENCLAW_REQUIRE_AUTH=1
OPENCLAW_ALLOWED_HOSTS=127.0.0.1,localhost
OPENCLAW_ALLOWED_TOOLS=bash,read,write,search,test
OPENCLAW_DENIED_TOOLS=browser,cron,nodes,canvas,gateway,discord,slack,telegram,whatsapp
OPENCLAW_DEFAULT_TOOL_SCOPE=bash,read,write,search,test
OPENCLAW_ENFORCE_POLICY_FOR_L4=1
OPENCLAW_SANDBOX_PROFILE=strict

# OpenClaw runtime adapter
OPENCLAW_BASE_URL=http://127.0.0.1:3001
OPENCLAW_EXECUTE_PATH=/api/tasks/execute
OPENCLAW_RUNTIME_SUBMIT_PATH=/runtime/tasks
OPENCLAW_RUNTIME_STATUS_PATH_PREFIX=/runtime/tasks/
OPENCLAW_API_KEY=
OPENCLAW_TIMEOUT_MS=12000

# Auth RBAC
AUTH_SESSION_TTL_MS=28800000
AUTH_SESSION_SLIDING=1
AUTH_SINGLE_SESSION_PER_USER=0
AUTH_PASSWORD_PEPPER=
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MS=900000
AUTH_FAIL_WINDOW_MS=600000
# 生产环境建议开启，强制必须使用 AUTH_USERS_FILE 或 AUTH_USERS_JSON
# AUTH_REQUIRE_EXTERNAL_USERS=1
# AUTH_USERS_FILE=./config/admin-users.local.json
# AUTH_USERS_JSON=[{"username":"admin","displayName":"系统管理员","role":"super_admin","passwordHash":"..."}]

# Front knowledge entry (external OSS project only)
FRONT_KNOWLEDGE_ENTRY_ENABLED=1
FRONT_KNOWLEDGE_ENTRY_MODE=external
WEKNORA_WEB_URL=http://127.0.0.1:19080
KNOWLEDGE_SSO_BRIDGE_ENABLED=0
KNOWLEDGE_SSO_BRIDGE_SHARED_SECRET=
KNOWLEDGE_SSO_BRIDGE_ISSUER=dcf
KNOWLEDGE_SSO_BRIDGE_AUDIENCE=weknora
KNOWLEDGE_SSO_BRIDGE_TTL_SECONDS=120
KNOWLEDGE_SSO_BRIDGE_LOGIN_PATH=/login
KNOWLEDGE_SSO_BRIDGE_REDIRECT_PATH=/platform/knowledge-bases
